{
  "name": "ncubelab-image-assessment-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Small Node.js website for AWS image assessment testing.",
  "main": "server.js",
  "scripts": {
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./src/styles.css -o ./public/styles.css --minify",
    "dev": "npm run build && node server.js",
